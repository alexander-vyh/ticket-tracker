{
  "name": "@flight-finder/cli",
  "version": "0.13.0",
  "private": true,
  "type": "module",
  "bin": {
    "flight-finder-tui": "./dist/index.js",
    "flightfinder-tui": "./dist/index.js"
  },
  "scripts": {
    "dev": "doppler run -- node --import tsx/esm --import ./register.mjs src/index.tsx",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "doppler run -- node --import tsx/esm --import ./register.mjs src/e2e-test.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "chalk": "^5.4.0",
    "commander": "^15.0.0",
    "ink": "^7.1.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "eslint": "^10.6.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.8"
  }
}
