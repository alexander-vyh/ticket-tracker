{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@/generated/*": ["../../apps/web/src/generated/*"],
      "@/*": ["./src/*"]
