# ============================================================
# Flight Finder -- Self-Hosted Configuration
# ============================================================
# Copy this file: cp .env.example .env
# Then edit the values below.
#
# Only ONE LLM provider API key is required -- pick whichever you have.
# ============================================================

# --- Database (defaults work with docker compose) ---
# The installer generates a random password. Do NOT leave this as-is in production.
POSTGRES_PASSWORD=change-me-to-a-random-value
# DATABASE_URL is set automatically by docker-compose.yml (db name: flight_finder)
# Only set this if running without Docker:
# DATABASE_URL=postgresql://postgres:change-me-to-a-random-value@localhost:5432/flight_finder

# --- Cache (optional -- comment out to disable) ---
# REDIS_URL is set automatically by docker-compose.yml
# Only set this if running without Docker:
# REDIS_URL=redis://localhost:6379

# --- LLM Provider (at least one required) ---
# Anthropic -- https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI -- https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# Optional: point to an OpenAI-compatible endpoint (OpenRouter, llama.cpp, Ollama, vLLM, etc.)
# When set, you can type any model ID in the admin config (e.g. llama-3.1-70b, mixtral-8x7b).
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Google AI -- https://aistudio.google.com/apikey
# GOOGLE_AI_API_KEY=

# Ollama -- select "Ollama" in admin config, no API key needed
# OLLAMA_HOST=http://localhost:11434
# The base URL defaults to $OLLAMA_HOST/v1 (or http://localhost:11434/v1).

# llama.cpp -- select "llama.cpp" in admin config, no API key needed
# Base URL defaults to http://localhost:8080/v1. Configurable in admin UI.

# Claude Code and Codex CLIs are auto-detected when their binaries are installed
# and host auth is mounted (~/.claude, ~/.codex via docker-compose volumes).

# --- Admin ---
# Leave empty for auto-generation on first run (printed in logs)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
CRON_SECRET=

# --- Self-Hosted Mode ---
# Set to 'true' when running your own instance. Enables multi user mode,
# setup wizard, and community data sharing opt-in.
# SELF_HOSTED=false

# --- Reverse Proxy / IP Trust ---
# Set to 'true' if a trusted reverse proxy (Caddy, nginx, Traefik) sits in
# front of Flight Finder and sets X-Forwarded-For. Leave 'false' (or unset)
# when the container is directly internet-facing to prevent IP spoofing in
# rate-limit keys and analytics.
# TRUSTED_FORWARDED_FOR=false

# --- Community Data Sharing (opt-in) ---
# URL of the central Flight Finder hub for aggregated price data.
# COMMUNITY_HUB_URL=https://flight-finder.org

# Allow public registration of community API keys (POST /api/community/register).
# Off by default. The admin toggle "Accept community registrations" in Settings is
# the primary control; this env var is an override that also opens registration
# when set to 'true' (handy for headless hub setups).
# COMMUNITY_REGISTRATION_OPEN=false

# --- Cron (built-in scheduler) ---
# Set to false to disable built-in scrape scheduler (e.g., if using external cron)
# CRON_ENABLED=true
# CRON_INTERVAL_HOURS=3

# --- Port (default: 3003) ---
# Host port to access Flight Finder (the container always listens on 3003 internally)
# HOST_PORT=3003

# --- Public Base URL ---
# Full URL of this instance, used for notification deep links. Defaults to
# APP_URL env var if set, otherwise falls back to ExtractionConfig.publicBaseUrl.
# APP_URL=https://your-domain.example

# --- LLM Rate-Limit Overrides ---
# Per-provider requests-per-minute caps. Defaults are built in; override here
# if your plan has a different quota.
# ANTHROPIC_RPM=50
# GOOGLE_RPM=15
# OPENAI_RPM=60
# GROQ_RPM=30

# --- Preview Concurrency ---
# Playwright instances used in parallel for the create-time preview scrape.
# PREVIEW_CONCURRENCY=2
# Max concurrent preview runs admitted per client IP.
# PREVIEW_ADMISSION_CAP=2

# --- VPN Price Comparison (ExpressVPN) ---
# Activation code from https://www.expressvpn.com/setup
# EXPRESSVPN_CODE=

# --- Advanced / Internal ---
# Path to Chromium executable (overrides Playwright's bundled browser)
# CHROME_PATH=
# SQLite path for the local analytics store
# ANALYTICS_DB_PATH=./data/analytics.db
# Build-time commit SHA injected by CI for /api/version
# NEXT_PUBLIC_COMMIT_SHA=
# Extraction timeout in milliseconds (default 90000). Raise for slow local models.
# EXTRACT_TIMEOUT_MS=90000
