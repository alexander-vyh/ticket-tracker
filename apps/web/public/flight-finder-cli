#!/usr/bin/env bash
set -euo pipefail

# Detect deprecated `fairtrail` invocation and print a one line notice.
# Set FLIGHT_FINDER_SILENCE_RENAME=1 to suppress. Sunset target: v1.0.
_FF_INVOKED_AS="$(basename "$0")"
if [ "$_FF_INVOKED_AS" = "fairtrail" ] && [ -z "${FLIGHT_FINDER_SILENCE_RENAME:-}" ]; then
  printf >&2 '\033[33mNote:\033[0m the `fairtrail` command has been renamed to `flight-finder` (or `flightfinder`). The old name still works but will be removed in v1.0. Set FLIGHT_FINDER_SILENCE_RENAME=1 to hide this notice.\n'
fi

# Flight Finder CLI — wraps Docker so you never have to think about it.
# Installed by: curl -fsSL https://flight-finder.org/install.sh | bash
#
# Usage:
#   flight-finder          Start Flight Finder (Ctrl+C to stop)
#   flight-finder start    Start in background
#   flight-finder stop     Stop Flight Finder
#   flight-finder logs     View live logs
#   flight-finder status   Check if running
#   flight-finder update   Pull latest version and restart
#   flight-finder search   Search and track a flight
#
# Aliases: flightfinder is a symlink. fairtrail kept working as a
# deprecated alias through v1.0 for existing installs.

BOLD='\033[1m'
DIM='\033[2m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
RESET='\033[0m'

FLIGHT_FINDER_DIR="$HOME/.flight-finder"
PORT="${HOST_PORT:-${PORT:-3003}}"
BASE_URL="${FLIGHT_FINDER_URL:-https://flight-finder.org}"

# Compose-flavor flag helpers (issue #72). Lives next to this script so
# `command -v flight-finder` and dev-mode (bin/flight-finder → apps/web/public/) both
# resolve it via dirname "$0". Required, not optional — a missing helper on
# podman would silently break `flight-finder --headless` again.
_FLAGS_LIB="$(dirname "$0")/flight-finder-cli-flags.sh"
if [ ! -f "$_FLAGS_LIB" ]; then
  printf "\033[0;31m\033[1m✗\033[0m Missing %s — re-run installer:\n  curl -fsSL %s/install.sh | bash\n" \
    "$_FLAGS_LIB" "${FLIGHT_FINDER_URL:-https://flight-finder.org}" >&2
  exit 1
fi
# shellcheck source=flight-finder-cli-flags.sh
. "$_FLAGS_LIB"

if [ ! -f "$FLIGHT_FINDER_DIR/docker-compose.yml" ]; then
  printf "${RED}${BOLD}✗${RESET} Flight Finder not found. Run the installer first:\n"
  printf "  curl -fsSL https://flight-finder.org/install.sh | bash\n"
  exit 1
fi

cd "$FLIGHT_FINDER_DIR"

# Detect container runtime (prefer docker, fall back to podman)
if command -v docker &>/dev/null; then
  CONTAINER_CMD=docker
elif command -v podman &>/dev/null; then
  CONTAINER_CMD=podman
else
  printf "${RED}${BOLD}✗${RESET} Docker or Podman is required.\n"
  exit 1
fi

# Resolve override files
COMPOSE_FILES="-f docker-compose.yml"
[ -f "docker-compose.override.yml" ] && COMPOSE_FILES="$COMPOSE_FILES -f docker-compose.override.yml"
# Auto-include VPN sidecar only if EXPRESSVPN_CODE is set to a non-empty
# value at the start of a line (commented-out or unset entries don't count).
# Previous form `grep -q "EXPRESSVPN_CODE"` matched `# EXPRESSVPN_CODE=` too,
# silently enabling the VPN sidecar from a disabled-by-comment placeholder.
if [ -f "docker-compose.vpn.yml" ] \
  && grep -Eq '^[[:space:]]*EXPRESSVPN_CODE=.+' .env 2>/dev/null; then
  COMPOSE_FILES="$COMPOSE_FILES -f docker-compose.vpn.yml"
fi

# Detect compose command based on detected container runtime
if [ "$CONTAINER_CMD" = "podman" ]; then
  # `podman compose` is a thin wrapper that shells out to an external provider
  # (docker-compose or the standalone podman-compose), it is not a native
  # engine. When the active provider is podman-compose (Fedora's default) it
  # rejects Docker's -it/-i exec flags, so a successful `podman compose version`
  # is NOT proof that -it is safe (issue #96). The provider name surfaces in the
  # version output: both the ">>>> Executing external compose provider" banner
  # on stderr and the "podman-compose version N" line on stdout. Capture both
  # (2>&1 into a var so nothing leaks to the terminal) and, when podman-compose
  # is the provider, drive it directly: correct -T/empty flags via the helper
  # and no provider banner on every command.
  if _pc_probe=$(podman compose version 2>&1); then
    if printf '%s\n' "$_pc_probe" | grep -q 'podman-compose' \
        && command -v podman-compose &>/dev/null; then
      _DC="podman-compose"
    else
      _DC="podman compose"
    fi
  elif command -v podman-compose &>/dev/null; then
    _DC="podman-compose"
  else
    printf "${RED}${BOLD}✗${RESET} podman compose is required. Install: https://github.com/containers/podman-compose\n"
    exit 1
  fi
elif docker compose version &>/dev/null 2>&1; then
  _DC="docker compose"
elif command -v docker-compose &>/dev/null; then
  _DC="docker-compose"
else
  printf "${RED}${BOLD}✗${RESET} Neither 'docker compose' (v2) nor 'docker-compose' (v1) found.\n"
  exit 1
fi

dc() {
  $_DC $COMPOSE_FILES "$@"
}

format_time() {
  local iso="$1"
  if [ -z "$iso" ] || [ "$iso" = "null" ]; then
    echo "unknown"
    return
  fi
  if date -j -f "%Y-%m-%dT%H:%M:%S" "${iso%%.*}" "+%H:%M" 2>/dev/null; then
    return
  fi
  date -d "$iso" "+%H:%M" 2>/dev/null || echo "$iso"
}

fetch_health() {
  curl -sf "http://localhost:${PORT}/api/health" 2>/dev/null
}

show_tracking_info() {
  local health
  health=$(fetch_health)
  if [ -z "$health" ]; then return; fi

  local queries next_scrape interval
  queries=$(echo "$health" | grep -o '"activeQueries":[0-9]*' | cut -d: -f2)
  next_scrape=$(echo "$health" | grep -o '"nextScrape":"[^"]*"' | cut -d'"' -f4)
  interval=$(echo "$health" | grep -o '"intervalHours":[0-9]*' | cut -d: -f2)

  if [ -n "$queries" ] && [ "$queries" != "0" ]; then
    local next_str
    next_str=$(format_time "$next_scrape")
    printf "  ${BOLD}%s${RESET} active queries — next scrape at ${BOLD}%s${RESET} (every %sh)\n" "$queries" "$next_str" "${interval:-3}"
  fi
}

cmd_start_foreground() {
  if [ "$CONTAINER_CMD" = "docker" ] && ! docker info &>/dev/null 2>&1; then
    printf "${RED}${BOLD}✗${RESET} Docker is not running. Start Docker Desktop and try again.\n"
    exit 1
  fi


  echo ""
  printf "${BOLD}  Flight Finder${RESET}\n"
  printf "  ${DIM}The price trail airlines don't show you${RESET}\n"
  echo ""

  dc up -d 2>&1 | while IFS= read -r line; do
    printf "  ${DIM}%s${RESET}\n" "$line"
  done

  printf "${CYAN}${BOLD}▸${RESET} Starting...\n"
  RETRIES=60
  until curl -sf "http://localhost:${PORT}/api/health" >/dev/null 2>&1; do
    RETRIES=$((RETRIES - 1))
    if [ "$RETRIES" -le 0 ]; then
      printf "${YELLOW}${BOLD}!${RESET} Took too long — check: flight-finder logs\n"
      break
    fi
    sleep 1
  done

  if [ "$RETRIES" -gt 0 ]; then
    printf "${GREEN}${BOLD}✓${RESET} Running at ${BOLD}http://localhost:${PORT}${RESET}\n"
    # Open browser
    if [ "$(uname)" = "Darwin" ] && command -v open &>/dev/null; then
      open "http://localhost:${PORT}"
    elif [ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ] && command -v xdg-open &>/dev/null; then
      xdg-open "http://localhost:${PORT}" >/dev/null 2>&1 &
    fi
  fi

  printf "  ${DIM}Press Ctrl+C to stop${RESET}\n"
  echo ""

  trap 'cmd_stop; exit 0' INT TERM
  dc logs -f web 2>/dev/null || true
}

cmd_start_background() {
  if [ "$CONTAINER_CMD" = "docker" ] && ! docker info &>/dev/null 2>&1; then
    printf "${RED}${BOLD}✗${RESET} Docker is not running. Start Docker Desktop and try again.\n"
    exit 1
  fi


  dc up -d 2>&1 | while IFS= read -r line; do
    printf "  ${DIM}%s${RESET}\n" "$line"
  done

  printf "${GREEN}${BOLD}✓${RESET} Flight Finder running at ${BOLD}http://localhost:${PORT}${RESET}\n"
  printf "  ${DIM}Stop with: flight-finder stop${RESET}\n"

  # Open browser
  if [ "$(uname)" = "Darwin" ] && command -v open &>/dev/null; then
    open "http://localhost:${PORT}"
  elif [ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ] && command -v xdg-open &>/dev/null; then
    xdg-open "http://localhost:${PORT}" >/dev/null 2>&1 &
  fi
}

cmd_stop() {
  echo ""
  local health
  health=$(fetch_health)
  if [ -n "$health" ]; then
    local queries next_scrape interval
    queries=$(echo "$health" | grep -o '"activeQueries":[0-9]*' | cut -d: -f2)
    next_scrape=$(echo "$health" | grep -o '"nextScrape":"[^"]*"' | cut -d'"' -f4)
    interval=$(echo "$health" | grep -o '"intervalHours":[0-9]*' | cut -d: -f2)

    if [ -n "$queries" ] && [ "$queries" != "0" ]; then
      local next_str
      next_str=$(format_time "$next_scrape")
      printf "  ${YELLOW}${BOLD}%s${RESET}${YELLOW} active queries tracking prices (next scrape at ${BOLD}%s${RESET}${YELLOW}, every %sh)${RESET}\n" "$queries" "$next_str" "${interval:-3}"
    fi
  fi

  read -rp "  Stop Flight Finder? [y/N] " confirm
  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    printf "  ${DIM}Cancelled${RESET}\n"
    return
  fi

  printf "${CYAN}${BOLD}▸${RESET} Stopping Flight Finder...\n"
  dc stop 2>/dev/null
  printf "${GREEN}${BOLD}✓${RESET} Stopped\n"
  printf "  ${YELLOW}Price tracking is paused — no scrapes will run until you start again.${RESET}\n"
  printf "  ${DIM}Your data and queries are saved. Run 'flightfinder' to resume.${RESET}\n"
}

cmd_logs() {
  dc logs -f web
}

cmd_status() {
  local health
  health=$(fetch_health)
  if [ -n "$health" ]; then
    printf "${GREEN}${BOLD}✓${RESET} Flight Finder is running at ${BOLD}http://localhost:${PORT}${RESET}\n"
    show_tracking_info
  else
    printf "${DIM}Flight Finder is not running. Start with: flightfinder${RESET}\n"
  fi
}

cmd_update() {
  printf "${CYAN}${BOLD}▸${RESET} Updating Flight Finder...\n"

  # Detect where the running binary lives (don't hardcode ~/.local/bin).
  # Try canonical first, then the legacy `fairtrail` install path so users on
  # the pre-rename binary update in place without reinstalling.
  CLI_PATH=$(command -v flight-finder 2>/dev/null || command -v fairtrail 2>/dev/null || echo "$HOME/.local/bin/flight-finder")
  CLI_DIR=$(dirname "$CLI_PATH")
  mkdir -p "$CLI_DIR"

  # Update CLI (download to temp, atomic move)
  if curl -fsSL "$BASE_URL/flight-finder-cli" -o "${CLI_PATH}.tmp"; then
    mv -f "${CLI_PATH}.tmp" "$CLI_PATH"
    chmod +x "$CLI_PATH"
    printf "${GREEN}${BOLD}✓${RESET} CLI updated\n"
  else
    rm -f "${CLI_PATH}.tmp"
    printf "${YELLOW}${BOLD}!${RESET} CLI update skipped (couldn't reach %s)\n" "$BASE_URL"
  fi

  # Refresh the compose-flavor flag helper alongside the CLI (issue #72).
  # If the CLI updated but the helper didn't, podman-compose users would
  # fall through to undefined `_compose_exec_flags`. Treat as best-effort:
  # the source guard at the top of the CLI errors out clearly if missing.
  FLAGS_PATH="${CLI_DIR}/flight-finder-cli-flags.sh"
  if curl -fsSL "$BASE_URL/flight-finder-cli-flags.sh" -o "${FLAGS_PATH}.tmp"; then
    mv -f "${FLAGS_PATH}.tmp" "$FLAGS_PATH"
  else
    rm -f "${FLAGS_PATH}.tmp"
    printf "${YELLOW}${BOLD}!${RESET} Flag helper update skipped (couldn't reach %s)\n" "$BASE_URL"
  fi

  # Try pulling pre-built image; fall back to local build if unavailable
  if ! dc pull web 2>&1 | while IFS= read -r line; do
    printf "  ${DIM}%s${RESET}\n" "$line"
  done; then
    printf "${YELLOW}${BOLD}!${RESET} No pre-built image for this architecture, building locally...\n"
    cd "$FLIGHT_FINDER_DIR"
    if [ -d repo/.git ]; then
      git -C repo pull --ff-only -q 2>/dev/null || true
    else
      git clone --depth 1 -q https://github.com/affromero/flight-finder.git repo
    fi
    dc build web 2>&1 | while IFS= read -r line; do
      printf "  ${DIM}%s${RESET}\n" "$line"
    done
  fi

  # Ensure db/redis are running but do not touch them.
  dc up -d --no-recreate db redis 2>&1 | while IFS= read -r line; do
    printf "  ${DIM}%s${RESET}\n" "$line"
  done

  # Force-recreate the web container so the freshly-pulled (or rebuilt)
  # image actually replaces the running one. Without --force-recreate,
  # podman-compose does not always detect that :latest now points to a
  # different digest and skips the recreate, leaving the user on the old
  # image even though the pull succeeded (issue #72).
  dc up -d --force-recreate --no-deps --remove-orphans web 2>&1 | while IFS= read -r line; do
    printf "  ${DIM}%s${RESET}\n" "$line"
  done

  printf "${GREEN}${BOLD}✓${RESET} Updated and restarted\n"
}

cmd_search() {
  local input="$*"
  if [ -z "$input" ]; then
    printf "${RED}${BOLD}✗${RESET} Usage: flight-finder search \"NYC to Tokyo next month\"\n"
    exit 1
  fi

  local health
  health=$(fetch_health)
  if [ -z "$health" ]; then
    printf "${RED}${BOLD}✗${RESET} Flight Finder is not running. Start with: flightfinder\n"
    exit 1
  fi

  printf "${CYAN}${BOLD}▸${RESET} Parsing: ${BOLD}%s${RESET}\n" "$input"

  # Step 1: Parse natural language query
  local parse_res
  parse_res=$(curl -sf "http://localhost:${PORT}/api/parse" \
    -H 'Content-Type: application/json' \
    -d "{\"query\": $(printf '%s' "$input" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')}" 2>/dev/null)

  if [ -z "$parse_res" ]; then
    printf "${RED}${BOLD}✗${RESET} Failed to reach Flight Finder API\n"
    exit 1
  fi

  local ok
  ok=$(echo "$parse_res" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('ok',''))" 2>/dev/null)
  if [ "$ok" != "True" ]; then
    local err
    err=$(echo "$parse_res" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('error','Unknown error'))" 2>/dev/null)
    printf "${RED}${BOLD}✗${RESET} %s\n" "$err"
    exit 1
  fi

  # Extract parsed fields
  local parsed_json
  parsed_json=$(echo "$parse_res" | python3 -c "
import json, sys
d = json.load(sys.stdin)
p = d['data']['parsed']
conf = d['data']['confidence']
print(json.dumps({'parsed': p, 'confidence': conf}))
" 2>/dev/null)

  local confidence
  confidence=$(echo "$parsed_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['confidence'])" 2>/dev/null)

  if [ "$confidence" != "high" ]; then
    printf "${YELLOW}${BOLD}!${RESET} Ambiguous query. Try being more specific (e.g. include airport codes and dates).\n"
    exit 1
  fi

  # Show what was parsed
  local origins destinations date_from date_to
  origins=$(echo "$parsed_json" | python3 -c "import json,sys; p=json.load(sys.stdin)['parsed']; print(', '.join(a['code'] for a in p.get('origins',[])))" 2>/dev/null)
  destinations=$(echo "$parsed_json" | python3 -c "import json,sys; p=json.load(sys.stdin)['parsed']; print(', '.join(a['code'] for a in p.get('destinations',[])))" 2>/dev/null)
  date_from=$(echo "$parsed_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['parsed']['dateFrom'])" 2>/dev/null)
  date_to=$(echo "$parsed_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['parsed']['dateTo'])" 2>/dev/null)

  printf "  ${BOLD}%s → %s${RESET}  ${DIM}%s to %s${RESET}\n" "$origins" "$destinations" "$date_from" "$date_to"
  printf "${CYAN}${BOLD}▸${RESET} Searching flights...\n"

  # Step 2: Preview flights
  local preview_body
  preview_body=$(echo "$parsed_json" | python3 -c "import json,sys; print(json.dumps(json.load(sys.stdin)['parsed']))" 2>/dev/null)

  local preview_res
  preview_res=$(curl -sf "http://localhost:${PORT}/api/preview" \
    -H 'Content-Type: application/json' \
    -d "$preview_body" 2>/dev/null)

  if [ -z "$preview_res" ]; then
    printf "${RED}${BOLD}✗${RESET} Flight search failed\n"
    exit 1
  fi

  # Step 3: Create tracker with all flights
  local create_body
  create_body=$(python3 -c "
import json, sys
parsed = json.loads('''$preview_body''')
preview = json.loads(sys.stdin.read())
routes = preview.get('data', {}).get('routes', [])
if not routes and preview.get('data', {}).get('flights'):
    routes = [{'origin': parsed['origin'], 'originName': parsed['originName'],
               'destination': parsed['destination'], 'destinationName': parsed['destinationName'],
               'flights': preview['data']['flights']}]
body = {
    'rawInput': '''$input''',
    'dateFrom': parsed['dateFrom'],
    'dateTo': parsed['dateTo'],
    'flexibility': parsed.get('flexibility', 0),
    'maxPrice': parsed.get('maxPrice'),
    'maxStops': parsed.get('maxStops'),
    'preferredAirlines': parsed.get('preferredAirlines', []),
    'timePreference': parsed.get('timePreference', 'any'),
    'currency': parsed.get('currency', 'USD'),
    'cabinClass': parsed.get('cabinClass', 'economy'),
    'tripType': parsed.get('tripType', 'round_trip'),
    'routes': [{'origin': r['origin'], 'originName': r.get('originName',''),
                'destination': r['destination'], 'destinationName': r.get('destinationName',''),
                'date': r.get('date'), 'returnDate': r.get('returnDate'),
                'selectedFlights': r.get('flights',[])} for r in routes]
}
print(json.dumps(body))
" <<< "$preview_res" 2>/dev/null)

  local create_res
  create_res=$(curl -sf "http://localhost:${PORT}/api/queries" \
    -H 'Content-Type: application/json' \
    -d "$create_body" 2>/dev/null)

  if [ -z "$create_res" ]; then
    printf "${RED}${BOLD}✗${RESET} Failed to create tracker\n"
    exit 1
  fi

  local create_ok
  create_ok=$(echo "$create_res" | python3 -c "import json,sys; print(json.load(sys.stdin).get('ok',''))" 2>/dev/null)

  if [ "$create_ok" != "True" ]; then
    local err
    err=$(echo "$create_res" | python3 -c "import json,sys; print(json.load(sys.stdin).get('error','Unknown error'))" 2>/dev/null)
    printf "${RED}${BOLD}✗${RESET} %s\n" "$err"
    exit 1
  fi

  # Show results
  local query_id
  query_id=$(echo "$create_res" | python3 -c "import json,sys; qs=json.load(sys.stdin)['data']['queries']; print(qs[0]['id'] if qs else '')" 2>/dev/null)
  local num_queries
  num_queries=$(echo "$create_res" | python3 -c "import json,sys; print(len(json.load(sys.stdin)['data']['queries']))" 2>/dev/null)

  echo ""
  printf "${GREEN}${BOLD}✓${RESET} Tracking ${BOLD}%s${RESET} route(s) — prices checked every 3h\n" "$num_queries"
  printf "  ${BOLD}http://localhost:%s/q/%s${RESET}\n" "$PORT" "$query_id"

  if [ "$(uname)" = "Darwin" ] && command -v open &>/dev/null; then
    open "http://localhost:${PORT}/q/${query_id}"
  elif [ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ] && command -v xdg-open &>/dev/null; then
    xdg-open "http://localhost:${PORT}/q/${query_id}" >/dev/null 2>&1 &
  fi
}

cmd_uninstall() {
  echo ""
  printf "${YELLOW}${BOLD}!${RESET} This will stop Flight Finder and remove all data.\n"
  read -rp "  Are you sure? [y/N] " confirm
  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    printf "  ${DIM}Cancelled${RESET}\n"
    return
  fi

  printf "${CYAN}${BOLD}▸${RESET} Removing Flight Finder...\n"
  dc down -v 2>/dev/null || true
  rm -rf "$FLIGHT_FINDER_DIR"
  rm -f "$HOME/.local/bin/flight-finder"
  printf "${GREEN}${BOLD}✓${RESET} Uninstalled\n"
}

cmd_version() {
  local version_json
  version_json=$(curl -sf "http://localhost:${PORT}/api/version" 2>/dev/null)
  if [ -n "$version_json" ]; then
    local ver commit
    ver=$(echo "$version_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['data']['current'])" 2>/dev/null)
    commit=$(echo "$version_json" | python3 -c "import json,sys; print(json.load(sys.stdin)['data'].get('commit','unknown'))" 2>/dev/null)
    printf "flightfinder ${BOLD}%s${RESET} ${DIM}(%s)${RESET}\n" "$ver" "${commit:0:7}"
  else
    printf "flightfinder ${DIM}(not running — start with: flightfinder)${RESET}\n"
  fi
}

cmd_help() {
  echo ""
  printf "${BOLD}  Flight Finder${RESET}\n"
  echo ""
  echo "  Usage: flight-finder [command]    (aliases: flightfinder, fairtrail)"
  echo ""
  echo "  Commands:"
  echo "    (none)       Start Flight Finder (Ctrl+C to stop)"
  echo "    search \"..\"  Search and track a flight from the terminal"
  echo "    start        Start in background"
  echo "    stop         Stop. Pauses all price tracking until you start again."
  echo "    logs         View live logs"
  echo "    status       Check if running"
  echo "    update       Pull latest version and restart"
  echo "    migrate      Migrate a pre-rename ~/.fairtrail install to ~/.flight-finder"
  echo "    version      Show version and commit"
  echo "    uninstall    Remove Flight Finder and all data"
  echo "    help         Show this help"
  echo ""
  echo "  Account recovery (self hosted multi user mode):"
  echo "    reset-password <username> <password>   Set a new password for a user"
  echo "    disable-accounts                       Turn multi user mode off (no login required)"
  echo ""
  echo "  Terminal UI flags (forwarded to flight-finder-tui inside the container):"
  echo "    --headless              Render the Ink terminal UI"
  echo "    --list                  List tracked queries (with --headless)"
  echo "    --view <id>             View a tracker (with --headless)"
  echo "    --backend <provider>    AI backend override (claude-code, codex, anthropic, openai, google)"
  echo "    --model <model>         Model override"
  echo ""
}

# Dispatch terminal UI flags to flight-finder-tui inside the running container.
cmd_tui() {
  local health
  health=$(fetch_health)
  if [ -z "$health" ]; then
    printf "${RED}${BOLD}✗${RESET} Flight Finder is not running. Start with: flightfinder\n"
    exit 1
  fi

  # Compose flavors disagree on exec flags (issue #72). _compose_exec_flags
  # picks -it/-i for docker-style, empty/-T for podman-compose standalone.
  local stdin_tty stdout_tty exec_flags
  [ -t 0 ] && stdin_tty=1 || stdin_tty=0
  [ -t 1 ] && stdout_tty=1 || stdout_tty=0
  exec_flags=$(_compose_exec_flags "$_DC" "$stdin_tty" "$stdout_tty")

  # `exec` cannot run shell functions, so call $_DC directly instead of dc().
  # $exec_flags is intentionally unquoted: empty string must word-split to
  # nothing, otherwise podman-compose receives an empty arg and rejects it.
  exec $_DC $COMPOSE_FILES exec $exec_flags web flight-finder-tui "$@"
}

# Recover a locked out multi user mode account by setting a new password.
# Runs the recovery path inside the container against the same DB.
cmd_reset_password() {
  local username="$1" newpass="$2"
  if [ -z "$username" ] || [ -z "$newpass" ]; then
    printf "${RED}${BOLD}✗${RESET} Usage: flight-finder reset-password <username> <new-password>\n"
    printf "  ${DIM}The password is visible in your shell history; clear it afterward.${RESET}\n"
    exit 1
  fi

  local health
  health=$(fetch_health)
  if [ -z "$health" ]; then
    printf "${RED}${BOLD}✗${RESET} Flight Finder is not running. Start with: flightfinder\n"
    exit 1
  fi

  # Same compose-flavor flag handling as cmd_tui (issue #72).
  local stdin_tty stdout_tty exec_flags
  [ -t 0 ] && stdin_tty=1 || stdin_tty=0
  [ -t 1 ] && stdout_tty=1 || stdout_tty=0
  exec_flags=$(_compose_exec_flags "$_DC" "$stdin_tty" "$stdout_tty")

  exec $_DC $COMPOSE_FILES exec $exec_flags web flight-finder-tui --reset-password "$username" --new-password "$newpass"
}

# Turn multi user mode off entirely. Drops the self hosted instance back to solo
# mode where no login is required, and clears the stored admin credential.
cmd_disable_accounts() {
  local health
  health=$(fetch_health)
  if [ -z "$health" ]; then
    printf "${RED}${BOLD}✗${RESET} Flight Finder is not running. Start with: flightfinder\n"
    exit 1
  fi

  local stdin_tty stdout_tty exec_flags
  [ -t 0 ] && stdin_tty=1 || stdin_tty=0
  [ -t 1 ] && stdout_tty=1 || stdout_tty=0
  exec_flags=$(_compose_exec_flags "$_DC" "$stdin_tty" "$stdout_tty")

  exec $_DC $COMPOSE_FILES exec $exec_flags web flight-finder-tui --disable-accounts
}

cmd_migrate() {
  printf "${CYAN}${BOLD}▸${RESET} Running Flight Finder migration...\n"
  if [ -d "$HOME/.fairtrail" ]; then
    printf "  ${DIM}Re-running the installer which auto-detects ~/.fairtrail and migrates.${RESET}\n"
    curl -fsSL "$BASE_URL/install.sh" | bash
  else
    ok "Nothing to migrate (no ~/.fairtrail directory found)"
    printf "  ${DIM}If you are already on Flight Finder, run \`flight-finder update\` instead.${RESET}\n"
  fi
}

case "${1:-}" in
  --headless|--list|--view|--backend|--model)
    cmd_tui "$@" ;;
  --tmux)
    printf "${YELLOW}${BOLD}!${RESET} --tmux is not supported in the production install. Use the dev mode CLI: npm run cli -- --tmux ...\n"
    exit 1 ;;
  search)    shift; cmd_search "$@" ;;
  reset-password)   shift; cmd_reset_password "$@" ;;
  disable-accounts) cmd_disable_accounts ;;
  start)     cmd_start_background ;;
  stop)      cmd_stop ;;
  logs)      cmd_logs ;;
  status)    cmd_status ;;
  update)    cmd_update ;;
  migrate)   cmd_migrate ;;
  version|-v|--version) cmd_version ;;
  uninstall) cmd_uninstall ;;
  help|-h|--help) cmd_help ;;
  "")        cmd_start_foreground ;;
  *)         echo "Unknown command: $1"; cmd_help; exit 1 ;;
esac
