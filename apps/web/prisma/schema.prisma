generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Query {
  id              String   @id @default(cuid())
  rawInput        String
  origin          String
  originName      String
  destination     String
  destinationName String
  dateFrom        DateTime
  dateTo          DateTime
  flexibility     Int      @default(0)
  maxPrice        Float?
  maxStops        Int?
  maxDurationHours Int?     // optional cap on total trip duration in hours
  preferredAirlines String[] @default([])
  preferredAggregators String[] @default([]) // per-query override of User.preferredAggregators; empty = inherit
  timePreference  String   @default("any")
  cabinClass      String   @default("economy")
  tripType        String   @default("round_trip") // 'one_way' | 'round_trip'
  currency        String?
  groupId         String?  // links sibling queries created from the same multi-route search
  deleteToken     String?
  active          Boolean  @default(true)
  isSeed          Boolean  @default(false)
  lookAheadDays   Int      @default(14)
  expiresAt       DateTime
  firstViewedAt   DateTime?
  vpnCountries    String[] @default([]) // ISO 3166-1 codes for VPN comparison
  label           String?
  scrapeInterval  Int?     // hours, null = follow extractionConfig.scrapeInterval (global)
  lastNotifiedLowPrice Float?    // price of the most recent new-low alert sent for this query (notification dedupe)
  lastNotifiedAt       DateTime? // when that last new-low alert was sent
  userId          String?  // owner when self-hosted multi-user is enabled; null = anonymous or seed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  snapshots PriceSnapshot[]
  fetchRuns FetchRun[]
  editEvents QueryEditEvent[]
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([active])
  @@index([expiresAt])
  @@index([isSeed])
  @@index([groupId])
  @@index([userId])
}

model QueryEditEvent {
  id        String   @id @default(cuid())
  queryId   String
  editedAt  DateTime @default(now())
  userId    String?
  summary   String
  changes   Json

  query Query @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@index([queryId, editedAt])
  @@index([userId])
}

model PriceSnapshot {
  id                String   @id @default(cuid())
  queryId           String
  travelDate        DateTime
  price             Float
  currency          String   @default("USD")
  airline           String
  bookingUrl        String?
  stops             Int      @default(0)
  duration          String?
  flightId          String?  // stable identity: airline-(flightNumber|HHMM)-origin-dest-date
  flightNumber      String?  // human-readable flight identifier (e.g. "DL 345")
  departureTime     String?
  arrivalTime       String?
  seatsLeft         Int?
  status            String   @default("available") // 'available' | 'sold_out'
  airlineDirectPrice Float?
  vpnCountry        String?  // ISO 3166-1 alpha-2 — VPN exit country during scrape
  scrapedAt         DateTime @default(now())
  fetchRunId        String?

  query    Query     @relation(fields: [queryId], references: [id], onDelete: Cascade)
  fetchRun FetchRun? @relation(fields: [fetchRunId], references: [id])

  @@index([queryId, scrapedAt])
  @@index([queryId, airline])
  @@index([queryId, flightId])
}

model FetchRun {
  id             String    @id @default(cuid())
  queryId        String
  status         String // 'success' | 'partial' | 'failed'
  source         String    @default("google_flights") // 'google_flights' | 'airline_direct' | 'skyscanner' | 'kayak' | 'manual' | joined labels e.g. 'google_flights+skyscanner'
  snapshotsCount Int       @default(0)
  extractionCost Float?
  vpnCountry     String?   // ISO 3166-1 alpha-2 — VPN exit country during this run
  error          String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  query     Query           @relation(fields: [queryId], references: [id], onDelete: Cascade)
  snapshots PriceSnapshot[]

  @@index([queryId, startedAt])
}

model ExtractionConfig {
  id                   String    @id @default("singleton")
  provider             String    @default("anthropic")
  model                String    @default("claude-haiku-4-5-20251001")
  theme                String    @default("default")
  enabled              Boolean   @default(true)
  scrapeInterval       Int       @default(3) // hours — global default
  defaultSearchMethod  String    @default("ai") // 'ai' | 'manual'
  adminPasswordHash    String?
  communitySharing     Boolean   @default(false)
  communityRegistrationOpen Boolean @default(false) // hub side: accept new community key registrations (opt-in). Env COMMUNITY_REGISTRATION_OPEN still works as an override.
  communityApiKey      String?
  lastCommunitySyncAt  DateTime?
  defaultCurrency      String?   // ISO 4217 (EUR, GBP). null = Google auto-detects
  defaultCountry       String?   // ISO 3166-1 alpha-2 (DE, GB). null = Google auto-detects
  customBaseUrl        String?   // e.g. http://localhost:11434/v1
  // Admin-entered provider API keys, encrypted at rest via lib/secret-crypto
  // (AES-256-GCM, keyed on ADMIN_SESSION_SECRET) exactly like vpnActivationCode.
  // Resolved BEFORE the matching env var so a self-hosted user can set a key in
  // the GUI without editing ~/.flight-finder/.env or restarting the stack (#149).
  anthropicApiKey      String?   // encrypted ANTHROPIC_API_KEY override
  openaiApiKey         String?   // encrypted OPENAI_API_KEY override
  googleApiKey         String?   // encrypted GOOGLE_AI_API_KEY override
  vpnProvider          String?   // 'none' | 'expressvpn'
  vpnCountries         String[]  @default([]) // default VPN countries (used when query has none)
  vpnActivationCode    String?   // encrypted VPN activation code
  multiUserMode        Boolean   @default(false) // self-hosted only; admin manages User table for households
  adminSessionsValidFrom DateTime? // admin sessions issued before this instant are revoked (set on admin password change)
  updatedAt            DateTime  @updatedAt
  extractTimeoutSeconds Int @default(90)
  maxFlightsPerDate     Int @default(10) // max flights the LLM extracts per date pair; raise for busy routes
  maxTrackedPerRoute    Int @default(10) // max flights a user can select to track per route in the picker; bounded by maxFlightsPerDate
  previewMaxCombos      Int @default(24) // max (routes x dates) the create-time preview scrape fans out; cron does the full grid
  aggregatorsEnabled    String[] @default(["google_flights", "airline_direct"]) // sources allowed in the fallback chain; skyscanner/kayak opt-in
  notifyMinDropAbs      Float    @default(5)  // minimum absolute price drop (in the query's currency) to fire a new-low alert
  notifyMinDropPct      Float    @default(0)  // minimum fractional drop (0..1) to fire a new-low alert; 0 = absolute floor only
  publicBaseUrl         String?  // this instance's public URL for notification deep links; null = APP_URL env / default
  anthropicRpm          Int?     // override Anthropic requests-per-minute cap; null = ANTHROPIC_RPM env / built-in default
  googleRpm             Int?     // override Google/Gemini requests-per-minute cap; null = GOOGLE_RPM env / built-in default
  openaiRpm             Int?     // override OpenAI requests-per-minute cap; null = OPENAI_RPM env / built-in default
  groqRpm               Int?     // override Groq requests-per-minute cap; null = GROQ_RPM env / built-in default
  previewConcurrency    Int?     // parallel Playwright instances for the create-time preview; null = PREVIEW_CONCURRENCY env / default
  previewAdmissionCap   Int?     // max concurrent preview runs per client IP; null = PREVIEW_ADMISSION_CAP env / default
}

model User {
  id                String   @id @default(cuid())
  username          String   @unique
  displayName       String?
  passwordHash      String?  // null = passwordless member (taps to sign in); admins always have one
  sessionsValidFrom DateTime? // sessions issued before this instant are revoked (set on password change/reset)
  isAdmin           Boolean  @default(false)
  avatar            String?  // preset avatar slug (see lib/avatars.ts); null falls back to initials
  theme             String?  // personal theme id (see lib/theme.ts); null falls back to ExtractionConfig.theme
  defaultCurrency   String?  // override; null falls back to ExtractionConfig.defaultCurrency
  defaultCountry    String?  // override; null falls back to ExtractionConfig.defaultCountry
  preferredAirlines    String[] @default([])
  preferredAggregators String[] @default([]) // ordered fallback chain after airline_direct; empty = inherit admin default
  cabinClass        String?  // override; null falls back to "economy"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  queries  Query[]
  channels NotificationChannel[]

  @@index([isAdmin])
}

model NotificationChannel {
  id        String   @id @default(cuid())
  userId    String?  // owner; null = global/admin-owned (single-user self-hosted). set = per-user (multi-user mode)
  type      String   // 'telegram' | 'email' | 'ntfy' | 'webhook'
  label     String?  // friendly name shown in the admin UI
  config    Json     // per-type settings; secret fields stored encrypted (see lib/notifications/channels)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([enabled])
}


model ApiUsageLog {
  id           String   @id @default(cuid())
  provider     String
  model        String
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  operation    String
  durationMs   Int
  error        String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([provider])
}

model PreviewRun {
  id             String   @id @default(cuid())
  requestHash    String
  status         String   @default("pending") // 'pending' | 'running' | 'completed' | 'failed'
  requestPayload Json
  resultPayload  Json?
  error          String?
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  /// IP that started this run. Used by the POST handler to cap concurrent
  /// active previews per source (issue 65 audit finding D2). Nullable so
  /// requests behind a proxy that strips x-forwarded-for still admit.
  clientIp       String?

  @@index([status, createdAt])
  @@index([expiresAt])
  @@index([requestHash, status, expiresAt])
  @@index([clientIp, status, updatedAt])
}

model CommunityApiKey {
  id            String    @id @default(cuid())
  apiKey        String    @unique
  label         String?
  active        Boolean   @default(true)
  snapshotCount Int       @default(0)
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())

  snapshots CommunitySnapshot[]

  @@index([active])
}

model CommunitySnapshot {
  id          String   @id @default(cuid())
  origin      String   // 3-letter IATA
  destination String   // 3-letter IATA
  travelDate  DateTime
  price       Float
  currency    String   @default("USD")
  airline     String
  stops       Int      @default(0)
  cabinClass  String   @default("economy")
  scrapedAt   DateTime
  receivedAt  DateTime @default(now())
  apiKeyId    String

  apiKey CommunityApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([origin, destination])
  @@index([travelDate])
  @@index([airline])
  @@index([apiKeyId])
}
